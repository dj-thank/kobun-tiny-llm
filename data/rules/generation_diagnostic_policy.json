    },
    {
      "id": "modern_intrusion_guard",
      "dimension_ids": ["modern_japanese_intrusion", "genji_era_scope", "degeneration"],
      "prompt": "もの思ふころ、",
      "provenance": "project-authored diagnostic probe",
      "trainable": false
    }
  ]
}
